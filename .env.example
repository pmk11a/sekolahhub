# ===========================================
# DATABASE — SHARED HOSTING (MySQL)
# ===========================================
# Cari info database di cPanel:
# 1. Login cPanel → "MySQL Databases"
# 2. Buat database baru (misal: cpuser_sekolahhub)
# 3. Buat user + password
# 4. Assign user ke database (ALL PRIVILEGES)
# 5. Host biasanya: localhost
# ===========================================
DATABASE_URL="mysql://cpuser_sekolahhub:password@localhost/cpuser_sekolahhub"

# ===========================================
# NEXTAUTH SETUP
# ===========================================
NEXTAUTH_SECRET="ganti-dengan-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# STORAGE (Optional - untuk upload file)
# ===========================================
BLOB_READ_WRITE_TOKEN=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME=""
AWS_REGION="ap-southeast-1"

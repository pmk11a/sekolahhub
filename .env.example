# ===========================================
# DATABASE SETUP
# ===========================================
# Untuk development local, gunakan database remote:
# - Railway.app (https://railway.app) - Free tier
# - Neon.tech (https://neon.tech) - Free forever
# - Supabase (https://supabase.com) - Free tier
# - Shared hosting cPanel (jika punya)
#
# Setelah daftar, copy DATABASE_URL dan paste di bawah:
# ===========================================
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# ===========================================
# NEXTAUTH SETUP
# ===========================================
# Generate random secret:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ===========================================
NEXTAUTH_SECRET="ganti-dengan-random-string-yang-digenerate"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# STORAGE (Optional - untuk upload file)
# ===========================================
BLOB_READ_WRITE_TOKEN=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME=""
AWS_REGION="ap-southeast-1"
